{
  "name": "voicomp",
  "displayName": "Voicomp",
  "description": "A secure real-time voice assistant with controlled workspace access.",
  "version": "0.0.1",
  "publisher": "fortenemy",
  "license": "MIT",
  "engines": {
    "vscode": "^1.95.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "npm run typecheck && node ./scripts/esbuild.mjs --production",
    "watch": "node ./scripts/esbuild.mjs --watch",
    "lint": "npm run lint:code && npm run lint:format",
    "lint:code": "eslint . --max-warnings=0",
    "lint:format": "prettier --check .",
    "typecheck": "tsc -p tsconfig.extension.json && tsc -p tsconfig.webview.json && tsc -p tsconfig.unit.json",
    "test:unit": "vitest run",
    "test:integration": "npm run build && tsc -p test/integration/tsconfig.json && vscode-test",
    "test": "npm run test:unit && npm run test:integration",
    "vscode:prepublish": "npm run build",
    "package": "vsce package --no-dependencies --out artifacts/voicomp.vsix"
  },
  "contributes": {
    "commands": [
      {
        "command": "voicomp.openAssistant",
        "title": "Open Assistant",
        "category": "Voicomp"
      },
      {
        "command": "voicomp.setOpenAIApiKey",
        "title": "Set OpenAI API Key",
        "category": "Voicomp"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "voicomp",
          "title": "Voicomp",
          "icon": "media/voicomp.svg"
        }
      ]
    },
    "views": {
      "voicomp": [
        {
          "id": "voicomp.assistant",
          "name": "Assistant",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Voicomp",
      "properties": {
        "voicomp.logging.level": {
          "type": "string",
          "enum": [
            "off",
            "error",
            "info"
          ],
          "default": "info",
          "description": "Controls sanitized Voicomp Output Channel logging."
        }
      }
    }
  },
  "dependencies": {
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/mocha": "10.0.10",
    "@types/node": "20.17.58",
    "@types/vscode": "1.95.0",
    "@vscode/test-cli": "0.0.15",
    "@vscode/test-electron": "3.0.0",
    "@vscode/vsce": "3.9.2",
    "esbuild": "0.28.1",
    "eslint": "10.7.0",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  }
}
